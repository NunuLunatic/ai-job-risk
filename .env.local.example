# ================================================================
# ARIA AI替代风险测评 — 环境变量配置示例
# 使用方法：复制此文件为 .env.local，填入真实值
# ================================================================

# ── Supabase 配置 ────────────────────────────────────────────
# 在 https://app.supabase.com 创建项目后获取

# 项目 URL（公开，可暴露给前端）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public key（公开，仅允许匿名 INSERT，无读权限）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# Service Role key（⚠️ 机密！只在服务端 API Route 使用，绝不暴露给前端）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# ================================================================
# Supabase 建表 SQL（在 Supabase 控制台 SQL Editor 中运行）
# ================================================================
#
# CREATE TABLE quiz_stats (
#   id               uuid        DEFAULT gen_random_uuid() PRIMARY KEY,
#   created_at       timestamptz DEFAULT now(),
#   industry         text,
#   job_type         text,
#   experience_band  text,
#   score_total      integer,
#   score_macro      integer,
#   score_task       integer,
#   score_org        integer,
#   score_company    integer,
#   score_moat       integer,
#   score_adapt      integer,
#   anxiety_level    integer,
#   ai_usage_level   integer,
#   adapt_confidence integer,
#   risk_tier        text,
#   anxiety_vs_risk  text,
#   app_version      text DEFAULT '0.4',
#   product_tier     text DEFAULT 'free',
#   platform         text,
#   session_id       text
# );
#
# -- 开启行级安全
# ALTER TABLE quiz_stats ENABLE ROW LEVEL SECURITY;
#
# -- 允许匿名插入（anon key 调用时使用）
# CREATE POLICY "anon_insert"
#   ON quiz_stats FOR INSERT TO anon WITH CHECK (true);
#
# -- 只允许 service_role 查询（你的后台/管理员使用）
# CREATE POLICY "service_read"
#   ON quiz_stats FOR SELECT TO service_role USING (true);
#
# ================================================================
# 常用数据查询 SQL（在 Supabase 控制台运行）
# ================================================================
#
# -- 各行业平均风险分
# SELECT industry, COUNT(*) AS 测评人数,
#        ROUND(AVG(score_total), 1) AS 平均风险分
# FROM quiz_stats GROUP BY industry ORDER BY 平均风险分 DESC;
#
# -- 过去 7 天每日测评量
# SELECT DATE(created_at) AS 日期, COUNT(*) AS 测评次数
# FROM quiz_stats
# WHERE created_at > NOW() - INTERVAL '7 days'
# GROUP BY DATE(created_at) ORDER BY 日期;
#
# -- 焦虑 vs 客观风险 四象限分布
# SELECT anxiety_vs_risk AS 类型, COUNT(*) AS 人数
# FROM quiz_stats GROUP BY anxiety_vs_risk;
#
# ================================================================
